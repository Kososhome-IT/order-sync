// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
 provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model OrderSync {
  id                 Int      @id @default(autoincrement())
  netsuiteOrderId    String?  @unique
  shopifyOrderId     String?  @unique
  netsuiteCompanyId  String?
  originSystem       String   // SHOPIFY | NETSUITE
  lastSyncedFrom     String   // SHOPIFY | NETSUITE
  status             String   // PENDING | SUCCESS | FAILED | PARTIAL
  action             String   @default("CREATE")
  errorMessage       String?
  webhookPayload    Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  logs               OrderSyncLog[]
}

model OrderSyncLog {
  id              Int       @id @default(autoincrement())
  orderSyncId     Int
  orderSync       OrderSync @relation(fields: [orderSyncId], references: [id])
  sourceSystem    String
  direction       String
  eventType       String
  status          String
  message         String?
  rawPayload      Json?
  requestPayload  Json?
  responsePayload Json?
  errorPayload    Json?
  createdAt       DateTime @default(now())
}

model CompanyMapping {
  id                       String   @id @default(cuid())

  netsuiteCompanyId        String   @unique

  shopifyCompanyId         String
  shopifyCompanyName       String

  shopifyCompanyLocationId String

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model PaymentSync {
  id                  String   @id @default(cuid())

  netsuiteOrderId     String
  shopifyOrderId      String

  authorizationId     String

  paymentReference    String?

  capturedAmount      Float

  status              String

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

